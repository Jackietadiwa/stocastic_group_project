        "print(f\"\\nCurrent 12-month Euribor: {euribor_df[euribor_df['Tenor']=='12 months']['Rate (%)'].values[0]:.3f}%\")\n",
        "\n",
        "# Plot simulation results\n",
        "fig, axes = plt.subplots(1, 3, figsize=(18, 5))\n",
