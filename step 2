        "\n",
        "\n",
        "# Install required packages\n",
        "!pip install quantlib pandas numpy scipy matplotlib seaborn openpyxl\n",
        "\n",
        "# Import libraries\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "from scipy.optimize import minimize, differential_evolution\n",
        "from scipy.interpolate import CubicSpline\n",
        "import warnings\n",
        "warnings.filterwarnings('ignore')\n",
        "\n",
        "# Set random seed for reproducibility\n",
        "np.random.seed(42)\n",
        "\n",
        "# ============================================\n",
        "# DATA LOADING\n",
        "# ============================================\n",
        "\n",
        "# Upload the Excel file\n",
        "from google.colab import files\n",
        "print(\"Please upload the Option Data Excel file:\")\n",
        "uploaded = files.upload()\n",
        "\n",
        "# Load the data\n",
        "import io\n",
        "file_name = list(uploaded.keys())[0]\n",
        "df = pd.read_excel(io.BytesIO(uploaded[file_name]), sheet_name=0)\n",
        "\n",
        "# Display data\n",
        "print(\"\\n=== Option Data ===\")\n",
        "print(df.head(10))\n",
        "print(f\"\\nTotal rows: {len(df)}\")\n",
        "\n",
        "# Current stock price and risk-free rate\n",
        "S0 = 232.90  # USD\n",
        "r = 0.015    # 1.50% annual risk-free rate\n",
        "trading_days_per_year = 250\n",
        "\n",
        "# ============================================\n",
        "# HELPER FUNCTIONS\n",
        "# ============================================\n",
        "\n",
        "def days_to_years(days):\n",
        "    \"\"\"Convert days to years (250 trading days per year)\"\"\"\n",
        "    return days / trading_days_per_year\n",
        "\n",
        "def heston_characteristic_function(phi, S0, K, T, r, kappa, theta, sigma, v0, rho, option_type='C'):\n",
        "    \"\"\"\n",
        "    Heston model characteristic function for Lewis (2001) approach\n",
        "    \"\"\"\n",
        "    # Parameters\n",
        "    x0 = np.log(S0)\n",
        "    a = kappa * theta\n",
        "    xi = sigma\n",
        "\n",
        "    # Complex integration\n",
        "    d = np.sqrt((kappa - 0.5 * 1j * rho * sigma * phi)**2 + (phi**2 + 1j * phi) * sigma**2)\n",
        "    g = (kappa - 0.5 * 1j * rho * sigma * phi - d) / (kappa - 0.5 * 1j * rho * sigma * phi + d)\n",
        "\n",
        "    # Characteristic exponent\n",
        "    C = r * phi * 1j * T + a / sigma**2 * ((kappa - 0.5 * 1j * rho * sigma * phi - d) * T - 2 * np.log((1 - g * np.exp(-d * T)) / (1 - g)))\n",
        "    D = (kappa - 0.5 * 1j * rho * sigma * phi - d) / sigma**2 * (1 - np.exp(-d * T)) / (1 - g * np.exp(-d * T))\n",
        "\n",
        "    # Characteristic function\n",
        "    psi = np.exp(C + D * v0 + 1j * phi * x0)\n",
        "\n",
        "    return psi\n",
        "\n",
        "def heston_call_price_lewis(S0, K, T, r, kappa, theta, sigma, v0, rho):\n",
        "    \"\"\"\n",
        "    Heston call option price using Lewis (2001) Fourier transform method\n",
        "    \"\"\"\n",
        "    def integrand(phi):\n",
        "        if phi == 0:\n",
        "            return 0\n",
        "        psi = heston_characteristic_function(phi - 0.5j, S0, K, T, r, kappa, theta, sigma, v0, rho, 'C')\n",
        "        return np.real(np.exp(-1j * phi * np.log(K)) * psi / (phi**2 + 0.25))\n",
        "\n",
        "    # Numerical integration\n",
        "    from scipy.integrate import quad\n",
        "    integral, _ = quad(integrand, 0, 100, limit=1000)\n",
        "\n",
        "    price = S0 - np.sqrt(S0 * K) * np.exp(-r * T / 2) / np.pi * integral\n",
        "    return max(price, 0.01)  # Ensure positive price\n",
        "\n",
        "def heston_put_price_put_call_parity(call_price, S0, K, T, r):\n",
        "    \"\"\"Put price using put-call parity\"\"\"\n",
        "    put_price = call_price + K * np.exp(-r * T) - S0\n",
        "    return max(put_price, 0.01)\n",
        "\n",
        "def mse_error(params, observed_options, S0, r, option_type='C'):\n",
        "    \"\"\"\n",
        "    Mean Squared Error for calibration\n",
        "    \"\"\"\n",
        "    kappa, theta, sigma, v0, rho = params\n",
        "\n",
        "    # Parameter constraints\n",
        "    if kappa <= 0 or theta <= 0 or sigma <= 0 or v0 <= 0 or abs(rho) >= 1:\n",
        "        return 1e10\n",
        "\n",
        "    # Feller condition check\n",
        "    if 2 * kappa * theta <= sigma**2:\n",
        "        pass  # Warning but not penalizing heavily\n",
        "\n",
        "    total_error = 0\n",
        "    count = 0\n",
        "\n",
        "    for _, row in observed_options.iterrows():\n",
        "        T = days_to_years(row['Days to maturity'])\n",
        "        K = row['Strike']\n",
        "        market_price = row['Price']\n",
        "\n",
        "        if T <= 0:\n",
        "            continue\n",
        "\n",
        "        try:\n",
        "            call_price = heston_call_price_lewis(S0, K, T, r, kappa, theta, sigma, v0, rho)\n",
        "\n",
        "            if option_type == 'C':\n",
        "                model_price = call_price\n",
        "            else:  # Put option\n",
        "                model_price = heston_put_price_put_call_parity(call_price, S0, K, T, r)\n",
        "\n",
        "            error = (model_price - market_price) ** 2\n",
        "            total_error += error\n",
        "            count += 1\n",
        "\n",
        "        except Exception as e:\n",
        "            continue\n",
        "\n",
        "    if count == 0:\n",
        "        return 1e10\n",
        "\n",
        "    return total_error / count"
      ],
