        "# STEP 3: CIR Model Calibration for Interest Rates\n",
        "# ============================================\n",
        "\n",
        "print(\"\\n\" + \"=\"*60)\n",
        "print(\"STEP 3: CIR Model Calibration for Euribor Rates\")\n",
        "print(\"=\"*60)\n",
        "\n",
        "# Euribor data\n",
        "euribor_data = {\n",
        "    'Tenor': ['1 week', '1 month', '3 months', '6 months', '12 months'],\n",
        "    'Days': [7, 30, 90, 180, 365],\n",
        "    'Rate (%)': [0.648, 0.679, 1.173, 1.809, 2.556]\n",
        "}\n",
        "\n",
        "euribor_df = pd.DataFrame(euribor_data)\n",
        "euribor_df['Rate'] = euribor_df['Rate (%)'] / 100\n",
        "euribor_df['Time (years)'] = euribor_df['Days'] / 365\n",
        "\n",
        "print(\"\\nEuribor Term Structure:\")\n",
        "print(euribor_df)\n",
        "\n",
        "# Interpolate using cubic spline\n",
        "times = euribor_df['Time (years)'].values\n",
        "rates = euribor_df['Rate'].values\n",
        "\n",
        "# Create cubic spline interpolation\n",
        "cs = CubicSpline(times, rates, bc_type='natural')\n",
        "\n",
        "# Generate weekly rates for 12 months\n",
        "weekly_times = np.arange(7/365, 1.01, 7/365)\n",
        "weekly_rates = cs(weekly_times)\n",
        "\n",
        "print(f\"\\nInterpolated weekly rates for 12 months:\")\n",
        "print(f\"  Number of weeks: {len(weekly_times)}\")\n",
        "print(f\"  Rate range: {weekly_rates.min()*100:.3f}% to {weekly_rates.max()*100:.3f}%\")\n",
        "\n",
        "# Plot term structure\n",
        "fig, ax = plt.subplots(figsize=(10, 6))\n",
        "ax.plot(times * 365, rates * 100, 'bo-', label='Market Euribor Rates', markersize=10, linewidth=2)\n",
        "ax.plot(weekly_times * 365, weekly_rates * 100, 'r-', label='Cubic Spline Interpolation', linewidth=2, alpha=0.7)\n",
        "ax.set_xlabel('Time (days)', fontsize=12)\n",
        "ax.set_ylabel('Interest Rate (%)', fontsize=12)\n",
        "ax.set_title('Euribor Term Structure with Cubic Spline Interpolation', fontsize=14)\n",
        "ax.legend()\n",
        "ax.grid(True, alpha=0.3)\n",
        "plt.tight_layout()\n",
        "plt.savefig('euribor_term_structure.png', dpi=150)\n",
        "plt.show()\n",
        "\n",
        "def cir_zero_coupon_bond_price(T, a, b, sigma_cir, r0):\n",
        "    \"\"\"\n",
        "    CIR model zero-coupon bond price formula\n",
        "    \"\"\"\n",
        "    if a <= 0 or sigma_cir <= 0:\n",
        "        return np.exp(-r0 * T)\n",
        "\n",
        "    gamma = np.sqrt(a**2 + 2 * sigma_cir**2)\n",
        "    numerator = 2 * gamma * np.exp((a + gamma) * T / 2)\n",
        "    denominator = (gamma + a) * (np.exp(gamma * T) - 1) + 2 * gamma\n",
        "\n",
        "    B = numerator / denominator\n",
        "    A = (2 * gamma * np.exp((a + gamma) * T / 2) / ((gamma + a) * (np.exp(gamma * T) - 1) + 2 * gamma)) ** (2 * a * b / sigma_cir**2)\n",
        "\n",
        "    return A * np.exp(-B * r0)\n",
        "\n",
        "def cir_yield(T, a, b, sigma_cir, r0):\n",
        "    \"\"\"CIR model yield\"\"\"\n",
        "    P = cir_zero_coupon_bond_price(T, a, b, sigma_cir, r0)\n",
        "    if P <= 0:\n",
        "        return 0.01\n",
        "    return -np.log(P) / T\n",
        "\n",
        "def mse_error_cir(params, times, market_rates):\n",
        "    \"\"\"MSE for CIR model calibration\"\"\"\n",
        "    a, b, sigma_cir = params\n",
        "    r0 = market_rates[0]  # Initial rate (1-week rate)\n",
        "\n",
        "    if a <= 0 or b <= 0 or sigma_cir <= 0:\n",
        "        return 1e10\n",
        "\n",
        "    total_error = 0\n",
        "    for t, market_rate in zip(times, market_rates):\n",
        "        model_rate = cir_yield(t, a, b, sigma_cir, r0)\n",
        "        total_error += (model_rate - market_rate) ** 2\n",
        "\n",
        "    return total_error / len(times)\n",
        "\n",
        "# Calibrate CIR model to interpolated rates\n",
        "initial_cir = [0.5, 0.03, 0.1]  # [a, b, sigma]\n",
        "bounds_cir = [(0.01, 5), (0.001, 0.2), (0.001, 0.5)]\n",
        "\n",
        "print(\"\\nCalibrating CIR model to interpolated term structure...\")\n",
        "\n",
        "result_cir = minimize(\n",
        "    mse_error_cir, initial_cir,\n",
        "    args=(weekly_times, weekly_rates),\n",
        "    method='L-BFGS-B', bounds=bounds_cir,\n",
        "    options={'maxiter': 500, 'disp': False}\n",
        ")\n",
        "\n",
        "print(f\"\\n--- CIR Model Calibration Results ---\")\n",
        "print(f\"a (mean reversion speed): {result_cir.x[0]:.4f}\")\n",
        "print(f\"b (long-term mean rate): {result_cir.x[1]:.4f} ({result_cir.x[1]*100:.2f}%)\")\n",
        "print(f\"σ (volatility): {result_cir.x[2]:.4f}\")\n",
        "print(f\"MSE: {result_cir.fun:.8f}\")\n",
        "\n",
        "# Generate model yields\n",
        "r0 = weekly_rates[0]\n",
        "model_yields = [cir_yield(t, *result_cir.x, r0) for t in weekly_times]\n",
        "\n",
        "# Plot calibration fit\n",
        "fig, ax = plt.subplots(figsize=(10, 6))\n",
        "ax.plot(weekly_times * 365, weekly_rates * 100, 'bo-', label='Interpolated Market Rates', markersize=6, linewidth=2)\n",
        "ax.plot(weekly_times * 365, np.array(model_yields) * 100, 'r--', label='CIR Model Fit', linewidth=2)\n",
        "ax.set_xlabel('Time (days)', fontsize=12)\n",
        "ax.set_ylabel('Interest Rate (%)', fontsize=12)\n",
        "ax.set_title('CIR Model Calibration to Euribor Term Structure', fontsize=14)\n",
        "ax.legend()\n",
        "ax.grid(True, alpha=0.3)\n",
        "plt.tight_layout()\n",
        "plt.savefig('cir_calibration.png', dpi=150)\n",
        "plt.show()\n",
        "\n",
        "# ============================================\n",
        "# STEP 3h: CIR Model Simulation for 12-month Euribor\n",
        "# ============================================\n",
        "\n",
        "print(\"\\n\" + \"=\"*60)\n",
        "print(\"STEP 3h: CIR Model Simulation - 12-month Euribor Forecast\")\n",
        "print(\"=\"*60)\n",
        "\n",
        "def simulate_cir(r0, a, b, sigma_cir, T, n_steps, n_sims):\n",
        "    \"\"\"\n",
        "    Simulate CIR process using Euler discretization with reflection\n",
        "    \"\"\"\n",
        "    dt = T / n_steps\n",
        "    rates = np.zeros((n_sims, n_steps + 1))\n",
        "    rates[:, 0] = r0\n",
        "\n",
        "    for t in range(1, n_steps + 1):\n",
        "        dW = np.random.normal(0, 1, n_sims) * np.sqrt(dt)\n",
        "        rates[:, t] = rates[:, t-1] + a * (b - rates[:, t-1]) * dt + sigma_cir * np.sqrt(np.maximum(rates[:, t-1], 0)) * dW\n",
        "        rates[:, t] = np.maximum(rates[:, t], 0)  # Reflection at zero\n",
        "\n",
        "    return rates\n",
        "\n",
        "# Simulation parameters\n",
        "n_sims_cir = 100000\n",
        "n_steps_cir = 365  # Daily steps for 1 year\n",
        "T_cir = 1.0  # 1 year\n",
        "\n",
        "r0_cir = weekly_rates[0]  # Starting from 1-week rate\n",
        "\n",
        "print(f\"\\nCIR Simulation Parameters:\")\n",
        "print(f\"  Initial rate (r0): {r0_cir*100:.3f}%\")\n",
        "print(f\"  Mean reversion (a): {result_cir.x[0]:.4f}\")\n",
        "print(f\"  Long-term mean (b): {result_cir.x[1]*100:.2f}%\")\n",
        "print(f\"  Volatility (σ): {result_cir.x[2]:.4f}\")\n",
        "print(f\"  Simulations: {n_sims_cir:,}\")\n",
        "print(f\"  Time steps: {n_steps_cir} (daily)\")\n",
        "print(f\"  Horizon: 1 year\")\n",
        "\n",
        "# Run simulations\n",
        "print(\"\\nRunning CIR simulations...\")\n",
        "cir_simulations = simulate_cir(r0_cir, result_cir.x[0], result_cir.x[1], result_cir.x[2], T_cir, n_steps_cir, n_sims_cir)\n",
        "\n",
        "# Extract 12-month rates (final rates at T=1)\n",
        "final_rates = cir_simulations[:, -1]\n",
        "\n",
        "# Statistical analysis\n",
        "mean_final = np.mean(final_rates)\n",
        "std_final = np.std(final_rates)\n",
        "percentiles = np.percentile(final_rates, [1, 5, 95, 99])\n",
        "\n",
        "print(f\"\\n--- 12-month Euribor Forecast Results ---\")\n",
        "print(f\"Expected 12-month Euribor in 1 year: {mean_final*100:.3f}%\")\n",
