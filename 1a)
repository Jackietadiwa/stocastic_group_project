        "def heston_call_price_carr_madan(S0, K, T, r, kappa, theta, sigma, v0, rho, alpha=1.5):\n",
        "    \"\"\"\n",
        "    Heston call price using Carr-Madan (1999) FFT method\n",
        "    \"\"\"\n",
        "    def heston_char_func(u, t):\n",
        "        \"\"\"Heston characteristic function\"\"\"\n",
        "        i = complex(0, 1)\n",
        "        x0 = np.log(S0)\n",
        "\n",
        "        a = kappa * theta\n",
        "        xi = sigma\n",
        "\n",
        "        d = np.sqrt((kappa - 0.5 * i * rho * xi * u)**2 + (u**2 + i * u) * xi**2)\n",
        "        g = (kappa - 0.5 * i * rho * xi * u - d) / (kappa - 0.5 * i * rho * xi * u + d)\n",
        "\n",
        "        C = r * i * u * t + a / xi**2 * ((kappa - 0.5 * i * rho * xi * u - d) * t - 2 * np.log((1 - g * np.exp(-d * t)) / (1 - g)))\n",
        "        D = (kappa - 0.5 * i * rho * xi * u - d) / xi**2 * (1 - np.exp(-d * t)) / (1 - g * np.exp(-d * t))\n",
        "\n",
        "        psi = np.exp(C + D * v0 + i * u * x0)\n",
        "        return psi\n",
        "\n",
        "    def integrand(u):\n",
        "        numerator = np.exp(-1j * u * np.log(K)) * heston_char_func(u - (alpha + 1) * 1j, T)\n",
        "        denominator = alpha**2 + alpha - u**2 + 1j * (2 * alpha + 1) * u\n",
        "        return np.real(numerator / denominator)\n",
        "\n",
        "    from scipy.integrate import quad\n",
        "    integral, _ = quad(integrand, 0, 500, limit=1000)\n",
        "\n",
        "    price = np.exp(-alpha * np.log(K)) / np.pi * integral\n",
