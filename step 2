        "print(\"\\n\" + \"=\"*60)\n",
        "print(\"STEP 2: 60-day maturity - Bates Model (with jumps)\")\n",
        "print(\"=\"*60)\n",
        "\n",
        "def bates_characteristic_function(phi, S0, K, T, r, kappa, theta, sigma, v0, rho,\n",
        "                                   lambda_j, mu_j, sigma_j):\n",
        "    \"\"\"\n",
        "    Bates (1996) model characteristic function (Heston + Merton jumps)\n",
        "    \"\"\"\n",
        "    # First, Heston part\n",
        "    x0 = np.log(S0)\n",
        "    a = kappa * theta\n",
        "    xi = sigma\n",
        "\n",
        "    d = np.sqrt((kappa - 0.5 * 1j * rho * sigma * phi)**2 + (phi**2 + 1j * phi) * sigma**2)\n",
        "    g = (kappa - 0.5 * 1j * rho * sigma * phi - d) / (kappa - 0.5 * 1j * rho * sigma * phi + d)\n",
        "\n",
        "    C_heston = r * phi * 1j * T + a / sigma**2 * ((kappa - 0.5 * 1j * rho * sigma * phi - d) * T - 2 * np.log((1 - g * np.exp(-d * T)) / (1 - g)))\n",
        "    D_heston = (kappa - 0.5 * 1j * rho * sigma * phi - d) / sigma**2 * (1 - np.exp(-d * T)) / (1 - g * np.exp(-d * T))\n",
        "\n",
        "    psi_heston = np.exp(C_heston + D_heston * v0 + 1j * phi * x0)\n",
        "\n",
        "    # Jump component (Merton)\n",
        "    jump_part = np.exp(T * lambda_j * (np.exp(1j * phi * mu_j - 0.5 * phi**2 * sigma_j**2) - 1 - 1j * phi * (np.exp(mu_j + 0.5 * sigma_j**2) - 1)))\n",
        "\n",
        "    return psi_heston * jump_part\n",
        "\n",
        "def bates_call_price(S0, K, T, r, kappa, theta, sigma, v0, rho, lambda_j, mu_j, sigma_j):\n",
        "    \"\"\"Bates model call price using Fourier transform\"\"\"\n",
        "    def integrand(phi):\n",
        "        if phi == 0:\n",
        "            return 0\n",
        "        psi = bates_characteristic_function(phi - 0.5j, S0, K, T, r, kappa, theta, sigma, v0, rho, lambda_j, mu_j, sigma_j)\n",
        "        return np.real(np.exp(-1j * phi * np.log(K)) * psi / (phi**2 + 0.25))\n",
        "\n",
        "    from scipy.integrate import quad\n",
        "    integral, _ = quad(integrand, 0, 100, limit=1000)\n",
        "\n",
        "    price = S0 - np.sqrt(S0 * K) * np.exp(-r * T / 2) / np.pi * integral\n",
        "    return max(price, 0.01)\n",
        "\n",
        "def mse_error_bates(params, observed_options, S0, r):\n",
        "    \"\"\"MSE for Bates model calibration\"\"\"\n",
        "    kappa, theta, sigma, v0, rho, lambda_j, mu_j, sigma_j = params\n",
        "\n",
        "    # Parameter constraints\n",
        "    if kappa <= 0 or theta <= 0 or sigma <= 0 or v0 <= 0 or abs(rho) >= 1:\n",
        "        return 1e10\n",
        "    if lambda_j < 0 or sigma_j < 0:\n",
        "        return 1e10\n",
        "\n",
        "    total_error = 0\n",
        "    count = 0\n",
        "\n",
        "    for _, row in observed_options.iterrows():\n",
        "        T = days_to_years(row['Days to maturity'])\n",
        "        K = row['Strike']\n",
        "        market_price = row['Price']\n",
        "        opt_type = row['Type']\n",
        "\n",
        "        if T <= 0:\n",
        "            continue\n",
        "\n",
        "        try:\n",
        "            call_price = bates_call_price(S0, K, T, r, kappa, theta, sigma, v0, rho, lambda_j, mu_j, sigma_j)\n",
        "\n",
        "            if opt_type == 'C':\n",
        "                model_price = call_price\n",
        "            else:\n",
        "                model_price = heston_put_price_put_call_parity(call_price, S0, K, T, r)\n",
        "\n",
        "            error = (model_price - market_price) ** 2\n",
        "            total_error += error\n",
        "            count += 1\n",
        "        except:\n",
        "            continue\n",
        "\n",
        "    return total_error / count if count > 0 else 1e10\n",
        "\n",
        "# Filter 60-day options\n",
        "maturity_60_days = 60\n",
        "options_60d = df[df['Days to maturity'] == maturity_60_days].copy()\n",
        "options_60d_calls = options_60d[options_60d['Type'] == 'C']\n",
        "options_60d_puts = options_60d[options_60d['Type'] == 'P']\n",
        "all_options_60d = pd.concat([options_60d_calls, options_60d_puts])\n",
        "\n",
        "print(f\"\\n60-day options found:\")\n",
        "print(f\"  Calls: {len(options_60d_calls)}\")\n",
        "print(f\"  Puts: {len(options_60d_puts)}\")\n",
        "\n",
        "# Initial parameters for Bates (including jumps)\n",
        "initial_bates = [2.0, 0.04, 0.3, 0.04, -0.7, 0.1, -0.02, 0.1]\n",
        "bounds_bates = [(0.1, 15), (0.01, 0.5), (0.01, 1.5), (0.01, 0.5), (-0.99, 0.99),\n",
        "                (0, 2), (-0.5, 0.5), (0.01, 0.5)]\n",
        "\n",
        "print(\"\\nCalibrating Bates model to 60-day options...\")\n",
        "\n",
        "result_bates = minimize(\n",
        "    mse_error_bates, initial_bates,\n",
        "    args=(all_options_60d, S0, r),\n",
        "    method='L-BFGS-B', bounds=bounds_bates,\n",
        "    options={'maxiter': 500, 'disp': False}\n",
        ")\n",
        "\n",
        "print(f\"\\n--- Bates Model Calibration Results (60-day maturity) ---\")\n",
        "print(f\"κ (mean reversion): {result_bates.x[0]:.4f}\")\n",
        "print(f\"θ (long-term variance): {result_bates.x[1]:.4f}\")\n",
        "print(f\"σ (vol of vol): {result_bates.x[2]:.4f}\")\n",
        "print(f\"v0 (initial variance): {result_bates.x[3]:.4f}\")\n",
        "print(f\"ρ (correlation): {result_bates.x[4]:.4f}\")\n",
        "print(f\"λ (jump intensity): {result_bates.x[5]:.4f}\")\n",
        "print(f\"μ_j (mean jump size): {result_bates.x[6]:.4f}\")\n",
        "print(f\"σ_j (jump volatility): {result_bates.x[7]:.4f}\")\n",
        "print(f\"MSE: {result_bates.fun:.6f}\")\n",
        "\n",
        "# Generate fitted prices for 60-day options\n",
        "print(f\"\\n--- Bates Model Fit Comparison (60-day options) ---\")\n",
        "print(f\"{'Strike':>8} {'Type':>4} {'Market':>8} {'Model':>8} {'Error':>8}\")\n",
        "\n",
        "for _, row in options_60d.iterrows():\n",
        "    T = days_to_years(row['Days to maturity'])\n",
        "    K = row['Strike']\n",
        "    market_price = row['Price']\n",
        "    opt_type = row['Type']\n",
        "\n",
        "    call_price = bates_call_price(S0, K, T, r, *result_bates.x)\n",
        "\n",
        "    if opt_type == 'C':\n",
        "        model_price = call_price\n",
        "    else:\n",
        "        model_price = heston_put_price_put_call_parity(call_price, S0, K, T, r)\n",
        "\n",
        "    error = model_price - market_price\n",
        "    print(f\"{K:8.1f} {opt_type:4} {market_price:8.2f} {model_price:8.2f} {error:8.3f}\")\n",
        "\n",
        "# Plot Bates calibration results\n",
        "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
        "\n",
        "# Calls plot\n",
        "calls_60d = options_60d[options_60d['Type'] == 'C'].sort_values('Strike')\n",
        "call_prices_bates = []\n",
        "for _, row in calls_60d.iterrows():\n",
        "    T = days_to_years(row['Days to maturity'])\n",
        "    price = bates_call_price(S0, row['Strike'], T, r, *result_bates.x)\n",
        "    call_prices_bates.append(price)\n",
        "\n",
        "axes[0].plot(calls_60d['Strike'], calls_60d['Price'], 'bo-', label='Market Prices', markersize=8)\n",
        "axes[0].plot(calls_60d['Strike'], call_prices_bates, 'ro--', label='Bates Model', markersize=8)\n",
        "axes[0].set_xlabel('Strike Price ($)', fontsize=12)\n",
        "axes[0].set_ylabel('Option Price ($)', fontsize=12)\n",
        "axes[0].set_title(f'60-Day Call Options - Bates Model Calibration\\n(With Jumps)', fontsize=12)\n",
