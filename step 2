        "# Price using Bates model (calibrated to 60-day options)\n",
        "put_call_price = bates_call_price(S0, put_K, put_T, r, *result_bates.x)\n",
        "put_price = heston_put_price_put_call_parity(put_call_price, S0, put_K, put_T, r)\n",
        "\n",
        "print(f\"\\n--- 70-Day Put Option Pricing Results ---\")\n",
        "print(f\"  Call price (Bates model): ${put_call_price:.4f}\")\n",
        "print(f\"  Put price (via put-call parity): ${put_price:.4f}\")\n",
        "\n",
        "# Monte Carlo validation for put option\n",
        "def price_european_put_mc(S0, K, r, T, kappa, theta, sigma, v0, rho, lambda_j, mu_j, sigma_j, n_sims=50000, n_steps=252):\n",
        "    \"\"\"Price European put option using Monte Carlo with Bates model\"\"\"\n",
        "    dt = T / n_steps\n",
        "    S = np.zeros((n_sims, n_steps + 1))\n",
        "    v = np.zeros((n_sims, n_steps + 1))\n",
        "\n",
        "    S[:, 0] = S0\n",
        "    v[:, 0] = max(v0, 0.0001)\n",
        "\n",
        "    corr_matrix = np.array([[1.0, rho], [rho, 1.0]])\n",
        "    L = np.linalg.cholesky(corr_matrix)\n",
        "\n",
        "    # Jump parameters\n",
        "    jump_mean = mu_j\n",
        "    jump_std = sigma_j\n",
        "    jump_intensity = lambda_j * dt\n",
        "\n",
        "    for t in range(1, n_steps + 1):\n",
        "        Z = np.random.normal(0, 1, size=(n_sims, 2))\n",
        "        Z_corr = Z @ L.T\n",
        "\n",
        "        v_prev = np.maximum(v[:, t-1], 0.0001)\n",
        "        v[:, t] = v_prev + kappa * (theta - v_prev) * dt + sigma * np.sqrt(v_prev * dt) * Z_corr[:, 1]\n",
        "        v[:, t] = np.maximum(v[:, t], 0.0001)\n",
        "\n",
        "        # Diffusion part\n",
        "        dW = Z_corr[:, 0] * np.sqrt(dt)\n",
        "\n",
        "        # Jump part\n",
        "        jump_occurred = np.random.poisson(jump_intensity, n_sims)\n",
        "        jump_size = np.random.normal(jump_mean, jump_std, n_sims) * jump_occurred\n",
        "\n",
        "        S[:, t] = S[:, t-1] * np.exp((r - 0.5 * v_prev) * dt + np.sqrt(v_prev * dt) * dW + jump_size)\n",
        "\n",
        "    put_payoffs = np.maximum(K - S[:, -1], 0)\n",
        "    put_price_mc = np.exp(-r * T) * np.mean(put_payoffs)\n",
        "    std_error_mc = np.std(put_payoffs) * np.exp(-r * T) / np.sqrt(n_sims)\n",
        "\n",
        "    return put_price_mc, std_error_mc\n",
        "\n",
        "put_price_mc, put_std_error = price_european_put_mc(\n",
        "    S0, put_K, r, put_T, *result_bates.x, n_sims=50000\n",
        ")\n",
        "\n",
        "print(f\"\\n  Monte Carlo validation (50,000 simulations):\")\n",
        "print(f\"    Put price: ${put_price_mc:.4f}\")\n",
        "print(f\"    Standard error: ${put_std_error:.4f}\")\n",
        "print(f\"    Difference from closed-form: ${abs(put_price - put_price_mc):.4f}\")"
