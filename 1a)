        "all_options_15d = pd.concat([options_15d_calls, options_15d_puts])\n",
        "\n",
        "# Initial parameters [kappa, theta, sigma, v0, rho]\n",
        "initial_params = [2.0, 0.04, 0.3, 0.04, -0.7]\n",
