        "\n",
        "def simulate_heston_paths(S0, v0, r, kappa, theta, sigma, rho, T, n_steps, n_sims):\n",
        "    \"\"\"\n",
        "    Simulate Heston model paths using Euler discretization\n",
        "    \"\"\"\n",
        "    dt = T / n_steps\n",
        "    S = np.zeros((n_sims, n_steps + 1))\n",
        "    v = np.zeros((n_sims, n_steps + 1))\n",
        "\n",
        "    S[:, 0] = S0\n",
        "    v[:, 0] = max(v0, 0.0001)\n",
        "\n",
        "    # Cholesky decomposition for correlated Brownian motions\n",
        "    corr_matrix = np.array([[1.0, rho], [rho, 1.0]])\n",
        "    L = np.linalg.cholesky(corr_matrix)\n",
        "\n",
        "    for t in range(1, n_steps + 1):\n",
        "        # Generate correlated random numbers\n",
        "        Z = np.random.normal(0, 1, size=(n_sims, 2))\n",
        "        Z_corr = Z @ L.T\n",
        "\n",
        "        # Euler discretization\n",
        "        v_prev = np.maximum(v[:, t-1], 0.0001)\n",
        "        v[:, t] = v_prev + kappa * (theta - v_prev) * dt + sigma * np.sqrt(v_prev * dt) * Z_corr[:, 1]\n",
        "        v[:, t] = np.maximum(v[:, t], 0.0001)  # Keep variance positive\n",
        "\n",
        "        # Asset price evolution\n",
        "        S[:, t] = S[:, t-1] * np.exp((r - 0.5 * v_prev) * dt + np.sqrt(v_prev * dt) * Z_corr[:, 0])\n",
        "\n",
        "    return S, v\n",
        "\n",
        "def price_asian_call_mc(S0, K, r, T, kappa, theta, sigma, v0, rho, n_sims=100000, n_steps=252):\n",
        "    \"\"\"\n",
        "    Price Asian call option using Monte Carlo simulation\n",
        "    \"\"\"\n",
        "    print(f\"\\nRunning Monte Carlo simulation for Asian call option...\")\n",
        "    print(f\"  Simulations: {n_sims:,}\")\n",
        "    print(f\"  Time steps: {n_steps}\")\n",
