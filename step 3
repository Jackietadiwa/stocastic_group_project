        "time_grid = np.linspace(0, T_cir, n_steps_cir + 1) * 365\n",
        "\n",
        "axes[1].plot(time_grid, sample_paths.T * 100, alpha=0.3, linewidth=0.5)\n",
        "axes[1].axhline(y=mean_final * 100, color='red', linestyle='--', linewidth=2, label='Mean Path')\n",
