        "    # Calculate average price along each path (including S0)\n",
        "    avg_prices = np.mean(S_paths, axis=1)\n",
        "\n",
        "    # Asian call payoff\n",
        "    payoffs = np.maximum(avg_prices - K, 0)\n",
        "\n",
        "    # Discounted price\n",
        "    price = np.exp(-r * T) * np.mean(payoffs)\n",
        "\n",
        "    # Standard error\n",
        "    std_error = np.std(payoffs) * np.exp(-r * T) / np.sqrt(n_sims)\n",
